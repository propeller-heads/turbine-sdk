{
    "name": "turbine-sdk",
    "version": "0.9.1",
    "description": "Submit orders to Turbine",
    "type": "module",
    "sideEffects": false,
    "main": "./src/_cjs/index.js",
    "module": "./src/_esm/index.js",
    "types": "./src/_types/index.d.ts",
    "exports": {
        ".": {
            "types": "./src/_types/index.d.ts",
            "import": "./src/_esm/index.js",
            "require": "./src/_cjs/index.js"
        },
        "./models": {
            "types": "./src/_types/models.d.ts",
            "import": "./src/_esm/models.js",
            "require": "./src/_cjs/models.js"
        },
        "./turbineClient": {
            "types": "./src/_types/turbineClient.d.ts",
            "import": "./src/_esm/turbineClient.js",
            "require": "./src/_cjs/turbineClient.js"
        },
        "./constants": {
            "types": "./src/_types/constants.d.ts",
            "import": "./src/_esm/constants.js",
            "require": "./src/_cjs/constants.js"
        },
        "./config": {
            "types": "./src/_types/config.d.ts",
            "import": "./src/_esm/config.js",
            "require": "./src/_cjs/config.js"
        },
        "./web3Subscription": {
            "types": "./src/_types/web3Subscription.d.ts",
            "import": "./src/_esm/web3Subscription.js",
            "require": "./src/_cjs/web3Subscription.js"
        },
        "./permit2": {
            "types": "./src/_types/permit2.d.ts",
            "import": "./src/_esm/permit2.js",
            "require": "./src/_cjs/permit2.js"
        },
        "./errorHandling": {
            "types": "./src/_types/errorHandling.d.ts",
            "import": "./src/_esm/errorHandling.js",
            "require": "./src/_cjs/errorHandling.js"
        },
        "./abi": {
            "types": "./src/_types/abi.d.ts",
            "import": "./src/_esm/abi.js",
            "require": "./src/_cjs/abi.js"
        }
    },
    "files": [
        "src/**",
        "tsconfig*.json"
    ],
    "scripts": {
        "clean": "rm -rf src/_cjs src/_esm src/_types build dist src/*.tsbuildinfo",
        "build:esm": "tsc -p tsconfig.esm.json",
        "build:cjs": "tsc -p tsconfig.cjs.json",
        "build:types": "tsc -p tsconfig.types.json",
        "build": "yarn clean && yarn build:esm && yarn build:cjs && yarn build:types",
        "prepack": "yarn build",
        "test": "jest",
        "test-no-integration": "jest --testPathIgnorePatterns integration",
        "submit-orders": "ts-node scripts/submit-orders.ts",
        "add-liquidity": "ts-node scripts/add-liquidity.ts"
    },
    "dependencies": {
        "@uniswap/permit2-sdk": "^1.3.0",
        "moment": "^2.30.1",
        "ts-node": "^10.8.0",
        "typescript": "^5.3.3",
        "web3": "^4.9.0"
    },
    "devDependencies": {
        "@babel/preset-typescript": "^7.24.6",
        "@types/jest": "^30.0.0",
        "@types/node": "20",
        "jest": "^30.1.3",
        "mocha": "^9.2.2",
        "node-fetch": "^3.3.2",
        "prettier": "3.3.2",
        "ts-jest": "^29.1.5",
        "viem": "^2.33.2"
    },
    "peerDependencies": {
        "viem": "^2.33.2"
    },
    "packageManager": "yarn@4.7.0"
}
