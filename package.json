{
    "name": "@propellerheads/turbine-sdk",
    "version": "0.20.0",
    "description": "TypeScript SDK for the Turbine protocol",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc --noEmit",
        "test": "jest",
        "test-no-integration": "jest --testPathIgnorePatterns integration",
        "lint": "prettier --write .",
        "prepublishOnly": "yarn build",
        "submit-orders": "tsx scripts/submit-orders.ts",
        "get-order-states": "tsx scripts/get-order-states.ts",
        "list-pools": "tsx scripts/list-pools.ts",
        "create-pool": "tsx scripts/create-pool.ts",
        "add-liquidity": "tsx scripts/add-liquidity.ts",
        "remove-liquidity": "tsx scripts/remove-liquidity.ts",
        "remove-liquidity-onchain": "tsx scripts/remove-liquidity-onchain.ts",
        "execute-pending-onchain-intents": "tsx scripts/execute-pending-onchain-intents.ts",
        "approve-token": "tsx scripts/approve-token.ts",
        "approve-lp-token": "tsx scripts/approve-lp-token.ts",
        "get-permit2-nonce": "tsx scripts/get-permit2-nonce.ts",
        "create-keystore": "tsx scripts/create-keystore.ts",
        "migrate-env-to-keystore": "tsx scripts/migrate-env-to-keystore.ts"
    },
    "dependencies": {
        "@uniswap/permit2-sdk": "^1.3.0"
    },
    "optionalDependencies": {
        "tough-cookie": "^6.0.0"
    },
    "devDependencies": {
        "@babel/preset-typescript": "^7.24.6",
        "@types/jest": "^30.0.0",
        "@types/node": "20",
        "@types/prompts": "^2.4.9",
        "@types/tough-cookie": "^4.0.5",
        "jest": "^30.1.3",
        "moment": "^2.30.1",
        "node-fetch": "^3.3.2",
        "ox": "^0.8.6",
        "prettier": "3.3.2",
        "prompts": "^2.4.2",
        "ts-jest": "^29.1.5",
        "ts-node": "^10.8.0",
        "tsup": "^8.4.0",
        "tsx": "^4.21.0",
        "typescript": "^5.3.3",
        "viem": "^2.33.2",
        "web3": "^4.9.0"
    },
    "peerDependencies": {
        "viem": "^2.33.2"
    },
    "packageManager": "yarn@4.7.0"
}
