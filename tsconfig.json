{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "noEmit": true
    },
    "include": ["src/**/*"],
    "exclude": ["tests/**", "scripts/**", "dist/**", "build/**"]
}
