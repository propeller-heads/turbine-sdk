# Build output (dist/ is committed for git-based installs; will stop once published to npm)
build/

# TypeScript build artifacts
*.tsbuildinfo

# Legacy pre-built outputs
src/_cjs/
src/_esm/
src/_types/

# Ignore node_modules directory
node_modules/
.idea/

# Yarn
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Encrypted keystores containing private keys
# These files should never be committed to version control
scripts/.keystores/
!scripts/.keystores/EXAMPLE-DO-NOT-USE.json